# ConViCure Fundraising System - Environment Variables
# Copy this file to .env and fill in your credentials

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key
# Get from: https://resend.com/api-keys
# Domain: convicure.com should already be configured via Cloudflare
RESEND_API_KEY=your_resend_api_key_here

# Email Configuration
# This should be info@convicure.com (configured in Resend/Cloudflare)
FROM_EMAIL=info@convicure.com
FROM_NAME=George Vincent
